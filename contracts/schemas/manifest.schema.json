{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praxis.dev/schemas/manifest.schema.json",
  "title": "manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "bundleId", "artifacts"],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactType", "path", "sha256"],
        "properties": {
          "artifactType": {
            "type": "string",
            "enum": ["machine-definition", "capability-profile", "manifest"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
