{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praxis.dev/schemas/capability-profile.schema.json",
  "title": "capability-profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "capabilityId",
    "capabilityVersion",
    "machineCapabilityId",
    "id",
    "version",
    "machineDefinitionRef",
    "units",
    "spindle",
    "kinematicsSummary"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "capabilityId": {
      "type": "string",
      "minLength": 1
    },
    "capabilityVersion": {
      "type": "string",
      "minLength": 1
    },
    "machineCapabilityId": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "machineDefinitionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["machineId", "schemaVersion"],
      "properties": {
        "machineId": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "const": "1.0"
        }
      }
    },
    "units": {
      "type": "string",
      "enum": ["mm"]
    },
    "spindle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rpmMin", "rpmMax", "orientationCapability"],
      "properties": {
        "rpmMin": {
          "type": "number",
          "minimum": 0
        },
        "rpmMax": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "orientationCapability": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["machineDefinitionSource"],
      "properties": {
        "machineDefinitionSource": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputType", "inputPath", "pkmVersion"],
          "properties": {
            "inputType": {
              "type": "string",
              "minLength": 1
            },
            "inputPath": {
              "type": "string",
              "minLength": 1
            },
            "pkmVersion": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "fidelity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "truthLevel"],
          "properties": {
            "level": {
              "type": "string",
              "minLength": 1
            },
            "truthLevel": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "constraintSource": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "evidence"],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "evidence": {
              "type": "string",
              "minLength": 1
            },
            "lastAlignedAt": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "kinematicsSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bodyCount", "jointCount", "axisIds", "axisTypes"],
      "properties": {
        "bodyCount": {
          "type": "integer"
        },
        "jointCount": {
          "type": "integer"
        },
        "axisIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "axisTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["revolute", "prismatic"]
          }
        }
      }
    }
  }
}
