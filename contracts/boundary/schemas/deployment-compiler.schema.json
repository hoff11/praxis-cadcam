{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://praxis.cadcam/schemas/deployment-compiler/v1.0.0",
  "title": "Deployment Compiler",
  "description": "Frozen governed compile context used repeatedly for production translation. The three fields deploymentCompilerId, deploymentCompilerVersion, and digest map directly to deploymentCompilerRef.id, deploymentCompilerRef.version, and deploymentCompilerRef.digest in governed compile requests.",
  "type": "object",
  "required": [
    "deploymentCompilerId",
    "deploymentCompilerVersion",
    "digest",
    "machineDeploymentRef",
    "capabilityProfileRef",
    "policyPackRef",
    "controllerBaseRef",
    "compilerPins",
    "frozen"
  ],
  "properties": {
    "deploymentCompilerId": {
      "type": "string",
      "pattern": "^[a-z0-9\\-]+$",
      "description": "Canonical identity for this deployment compiler. Maps to deploymentCompilerRef.id in governed compile requests."
    },
    "deploymentCompilerVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of this deployment compiler artifact. Maps to deploymentCompilerRef.version in governed compile requests."
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Canonical digest of the frozen deployment-compiler payload. Maps to deploymentCompilerRef.digest in governed compile requests. Format: sha256:<64 lowercase hex>. Computed at freeze time and immutable."
    },
    "machineDeploymentRef": {
      "type": "object",
      "required": ["deploymentId", "deploymentVersion"],
      "properties": {
        "deploymentId": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+$"
        },
        "deploymentVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    },
    "capabilityProfileRef": {
      "type": "object",
      "required": ["capabilityId", "capabilityVersion"],
      "properties": {
        "capabilityId": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+$"
        },
        "capabilityVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    },
    "policyPackRef": {
      "type": "object",
      "required": ["policyPackId", "policyPackVersion"],
      "properties": {
        "policyPackId": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+$"
        },
        "policyPackVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    },
    "controllerBaseRef": {
      "type": "object",
      "required": ["controllerBaseId", "controllerBaseVersion"],
      "properties": {
        "controllerBaseId": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+$"
        },
        "controllerBaseVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    },
    "compilerPins": {
      "type": "object",
      "required": ["compilerVersion", "compilerBuild", "emitterVersion"],
      "properties": {
        "compilerVersion": {"type": "string"},
        "compilerBuild": {"type": "string"},
        "irVersion": {"type": "string"},
        "emitterVersion": {"type": "string"}
      },
      "additionalProperties": false
    },
    "trustedOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["overrideClass"],
        "properties": {
          "overrideClass": {"type": "string"},
          "value": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          },
          "approvedBy": {"type": "string"},
          "approvalRef": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "compilerRequestMapping": {
      "type": "object",
      "description": "Governed compile request target echo. Contains only targetSelection — machineCapabilityId is forbidden in governed mode and must not appear here.",
      "required": ["targetSelection"],
      "properties": {
        "targetSelection": {
          "type": "object",
          "required": ["machineProfile", "policyPack", "controllerBase"],
          "properties": {
            "machineProfile": {
              "type": "object",
              "required": ["id", "version"],
              "properties": {
                "id": {"type": "string", "pattern": "^[a-z0-9\\-]+$"},
                "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"}
              },
              "additionalProperties": false
            },
            "policyPack": {
              "type": "object",
              "required": ["id", "version"],
              "properties": {
                "id": {"type": "string", "pattern": "^[a-z0-9\\-]+$"},
                "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"}
              },
              "additionalProperties": false
            },
            "controllerBase": {
              "type": "object",
              "required": ["id", "version"],
              "properties": {
                "id": {"type": "string", "pattern": "^[a-z0-9\\-]+$"},
                "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"}
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "frozen": {
      "type": "object",
      "required": ["isFrozen", "frozenAt"],
      "properties": {
        "isFrozen": {"type": "boolean", "const": true},
        "frozenAt": {"type": "string", "format": "date-time"},
        "frozenBy": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
